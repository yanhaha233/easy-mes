POSTGRES_DB=easy_mes
POSTGRES_USER=easy_mes
POSTGRES_PASSWORD=change-this-postgres-password

AUTH_SECRET_KEY=change-this-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=480
CORS_ORIGINS=http://your-server-ip:8080
HTTP_PORT=8080
LOG_LEVEL=INFO

# Optional. Set only when an upstream ERP will push work orders or pull receipt feedback.
ERP_INTEGRATION_API_KEY=
